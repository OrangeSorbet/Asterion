{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "shell:allow-open",
    "fs:default",
    { "identifier": "fs:allow-read-text-file", "allow": [{ "path": "$RESOURCE/**" }, { "path": "$APPDATA/**" }, { "path": "**/theory.json" }] },
    { "identifier": "fs:allow-write-text-file", "allow": [{ "path": "$RESOURCE/**" }, { "path": "$APPDATA/**" }, { "path": "**/theory.json" }] },
    {
      "identifier": "fs:allow-write",
      "allow": [{ "path": "$APPDATA/**" }]
    }
  ]
}